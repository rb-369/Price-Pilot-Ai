# ── Server Environment Variables ──
# Copy to `.env` (local dev) or set these in your hosting provider's dashboard.

# Core
NODE_ENV=production
PORT=5000

# MongoDB (required)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/pricepilot?retryWrites=true&w=majority

# JWT signing secret (required, generate a strong random value)
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_64_char_random_string

# Allowed CORS origins (comma-separated). Include your Vercel frontend URL.
CLIENT_URL=https://price-pilot-ai.vercel.app
# Optional: regex for preview deployments
# CLIENT_URL_REGEX=https://.*\\.vercel\\.app$

# Redis (BullMQ + cache). On Render, set automatically from the linked Redis service.
# Locally: REDIS_URL=redis://localhost:6379
REDIS_URL=

# AI microservice (optional — if you deploy it). Leave blank to disable AI features.
AI_SERVICE_URL=
LLM_API_KEY=your_google_gemini_api_key
GEMINI_API_KEY=your_google_gemini_api_key

# Other data sources (optional)
SERPAPI_KEY=
OPENWEATHER_API_KEY=
NEWSAPI_KEY=
RAINFOREST_API_KEY=

# Email (optional — required for password reset emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Cron jobs: set to "1" on EXACTLY ONE production instance
# (otherwise scraping/demand collection will run multiple times).
ENABLE_CRON=0
